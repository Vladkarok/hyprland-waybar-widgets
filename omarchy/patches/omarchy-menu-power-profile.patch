    fix: make power profile menu reflect and apply current state

diff --git a/bin/omarchy-menu b/bin/omarchy-menu
index 3ee0ea5e..315f6d98 100755
--- a/bin/omarchy-menu
+++ b/bin/omarchy-menu
@@ -3,6 +3,7 @@
 # Launch the Omarchy Menu or takes a parameter to jump straight to a submenu.
 
 export PATH="$HOME/.local/share/omarchy/bin:$PATH"
+OMARCHY_BIN_DIR="$HOME/.local/share/omarchy/bin"
 
 # Set to true when going directly to a submenu, so we can exit directly
 BACK_TO_EXIT=false
@@ -242,12 +243,15 @@ show_setup_menu() {
 }
 
 show_setup_power_menu() {
-  profile=$(menu "Power Profile" "$(omarchy-powerprofiles-list)" "" "$(powerprofilesctl get)")
+  local current options profile
+  current=$(powerprofilesctl get)
+  options=$(printf '%s\n' "$current"; omarchy-powerprofiles-list | grep -vxF "$current")
+  profile=$(menu "Power Profile" "$options" "" "$current")
 
   if [[ $profile == "CNCLD" || -z $profile ]]; then
     back_to show_setup_menu
   else
-    powerprofilesctl set "$profile"
+    "$OMARCHY_BIN_DIR/omarchy-powerprofiles-apply" "$profile"
   fi
 }
 
