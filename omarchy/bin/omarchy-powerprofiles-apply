#!/bin/bash

set -euo pipefail

# Apply a power profile via power-profiles-daemon and recover from the
# intel_pstate state where governors are left pinned to "performance".

profile="${1:-}"

if [[ -z "$profile" ]]; then
  echo "Usage: omarchy-powerprofiles-apply <performance|balanced|power-saver>" >&2
  exit 2
fi

reset_governors() {
  local reset_cmd='
    for p in /sys/devices/system/cpu/cpufreq/policy*; do
      [[ -w "$p/scaling_governor" ]] || continue
      gov=$(cat "$p/scaling_governor" 2>/dev/null || true)
      if [[ "$gov" == "performance" ]]; then
        echo powersave > "$p/scaling_governor"
      fi
    done
  '

  if [[ $EUID -eq 0 ]]; then
    bash -lc "$reset_cmd"
  else
    sudo -n bash -lc "$reset_cmd"
  fi
}

governors_stuck_on_performance() {
  local p gov

  for p in /sys/devices/system/cpu/cpufreq/policy*; do
    gov=$(cat "$p/scaling_governor" 2>/dev/null || true)
    if [[ "$gov" == "performance" ]]; then
      return 0
    fi
  done

  return 1
}

apply_profile() {
  powerprofilesctl set "$profile"
}

set_profile() {
  local err=""

  if ! err=$(apply_profile 2>&1); then
    :
  fi

  if [[ "$profile" != "performance" ]] && governors_stuck_on_performance; then
    reset_governors
    apply_profile
  elif [[ -n "$err" ]]; then
    printf '%s\n' "$err" >&2
    return 1
  fi

  if [[ "$profile" != "performance" ]] && governors_stuck_on_performance; then
    echo "Failed to apply '$profile': CPU governors remained stuck on performance" >&2
    return 1
  fi
}

set_profile
